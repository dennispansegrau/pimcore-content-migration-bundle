{% autoescape false %}
private function {{ methodName }}(): {{ classname }}
    {
{% if settings.withDependencies() %}
{% include('@PimcoreContentMigration/code_templates/shared/_dependency_headers.php.twig') %}
        # Create {{ type }} {{ object.getFullPath() }}
        $builder = {{ builder }}::findOrCreate('{{ object.getFullPath() }}', {{ classname }}::class);
{# CONCRETE BUILDER SETTER #}
{% if isConcrete %}
        $builder->setPublished({{ object.getPublished() ? 'true' : 'false' }});
{% endif %}
{% if object.isLocked %}
        $builder->setLocked({{ pcmb_value_to_string(object.getLocked(), dependencies) }});
{% endif %}
{# DATA OBJECT BUILDER SETTER #}
{% for setter in setters %}
        $builder->set('{{ setter.name }}', {{ pcmb_value_to_string(setter.value, dependencies) }});
{% endfor %}
{% for property in object.getProperties %}
        $builder->setProperty('{{ property.getName() }}', '{{ property.getType() }}', {% if property.getType() == 'bool' %}{{ property.getData() ? 'true' : 'false' }}{% else %}'{{ property.getData() }}'{% endif %}, {{ property.getInherited() ? 'true' : 'false' }}, {{ property.getInheritable() ? 'true' : 'false' }});
{% endfor %}
        $builder->save();

        /** @var {{ classname }} */
        return $builder->getObject();
    }
{% include('@PimcoreContentMigration/code_templates/shared/_dependency_bodies.php.twig') %}
{% else %}
        $builder = {{ builder }}::findOrCreate('{{ object.getFullPath() }}', {{ classname }}::class);

        /** @var {{ classname }} */
        return $builder->getObject();
    }
{% endif %}
{% endautoescape %}