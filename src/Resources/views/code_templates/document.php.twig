{% autoescape false %}
private function {{ methodName }}(): {{ classname }}
    {
{% if builder is null %}
        // TODO: Insert a builder
        // No Builder found for type {{ type }}. Please create your own builder.
        // You can extend the \PimcoreContentMigration\Builder\Document\DocumentBuilder or any other builder.

{% set builder = '[YOUR-BUILDER]' %}
{% endif %}
{% if settings.withDependencies() %}
{% include('@PimcoreContentMigration/code_templates/shared/_dependency_headers.php.twig') %}
        # Create {{ type }} {{ document.getFullPath() }}
        $builder = {{ builder }}::findOrCreate('{{ document.getFullPath() }}');
{# BUILDER SPECIFIC SETTER #}
{% if type == 'email' %}
        $builder->setSubject('{{ document.getSubject() }}');
        $builder->setTo('{{ document.getTo() }}');
        $builder->setFrom('{{ document.getFrom() }}');
        $builder->setReplyTo('{{ document.getReplyTo() }}');
        $builder->setCc('{{ document.getCc() }}');
        $builder->setBcc('{{ document.getBcc() }}');
{% elseif type == 'folder' %}
{% elseif type == 'hardlink' %}
        $builder->setSourceId({% if document.getSourceId() %}{{ document.getSourceId() }}{% else %}null{% endif %});
        $builder->setPropertiesFromSource({{ document.getPropertiesFromSource() ? 'true' : 'false' }});
        $builder->setChildrenFromSource({{ document.getChildrenFromSource() ? 'true' : 'false' }});
{% elseif type == 'link' %}
        $builder->setDirect('{{ document.getDirect() }}');
        $builder->setLinktype('{{ document.getLinktype() }}');
{% elseif type == 'page' %}
        $builder->setDescription('{{ document.getDescription() }}');
        $builder->setTitle('{{ document.getTitle() }}');
        $builder->setPrettyUrl('{{ document.getPrettyUrl() }}');
{% elseif type == 'snippet' %}
{% elseif type == 'printpage' %}
{% elseif type == 'printcontainer' %}
{% elseif type == 'newsletter' %}
        $builder->setPlaintext('{{ document.getPlaintext() }}');
        $builder->setEnableTrackingParameters({{ document.getEnableTrackingParameters() ? 'true' : 'false' }});
        $builder->setTrackingParameterSource('{{ document.getTrackingParameterSource() }}');
        $builder->setTrackingParameterMedium('{{ document.getTrackingParameterMedium() }}');
        $builder->setTrackingParameterName('{{ document.getTrackingParameterName() }}');
        $builder->setSendingMode('{{ document.getSendingMode() }}');
{% endif %}
{# PAGE SNIPPET BUILDER SETTER #}
{% if isPageSnippet %}
        $builder->setController({% if document.getController() %}'{{ document.getController() }}'{% else %}null{% endif %});
        $builder->setContentMainDocument({{ pcmb_value_to_string(document.getContentMainDocument(), dependencies) }});
        $builder->setTemplate({% if document.getTemplate() %}'{{ document.getTemplate() }}'{% else %}null{% endif %});
{% for property in document.getProperties %}
        $builder->setProperty('{{ property.getName() }}', '{{ property.getType() }}', {{ pcmb_value_to_string(property.getData(), dependencies) }}, {{ property.getInherited() ? 'true' : 'false' }}, {{ property.getInheritable() ? 'true' : 'false' }});
{% endfor %}
{% include('@PimcoreContentMigration/code_templates/document/_editables.php.twig') %}
{% endif %}
{# PRINT ABSTRACT BUILDER SETTER #}
{% if isPrintAbstract and document.getLastGeneratedDate() %}
        $builder->setLastGeneratedDate(new \DateTime('{{ document.getLastGeneratedDate()|date(constant('DateTime::ATOM')) }}'));
{% endif %}
{% if isPrintAbstract and document.getLastGenerated() %}
        $builder->setLastGenerated({{ document.getLastGenerated() }});
{% endif %}
{% if isPrintAbstract and document.getLastGenerateMessage() %}
        $builder->setLastGenerateMessage('{{ document.getLastGenerateMessage() }}');
{% endif %}
{# Personalization Bundle Interface SETTER #}
{% if isImplementingTargetingDocumentInterface %}
{% if type == 'page' %}
        $builder->setTargetGroupIds('{{ document.getTargetGroupIds() }}');
{% endif %}
        $builder->setUseTargetGroup({{ pcmb_value_to_string(document.getUseTargetGroup(), dependencies) }});
{% endif %}
{# DOCUMENT BUILDER SETTER #}
{% if document.isLocked %}
        $builder->setLocked({{ pcmb_value_to_string(document.getLocked(), dependencies) }});
{% endif %}
        $builder->setIndex({{ document.getIndex() }});
        $builder->setType('{{ document.getType() }}');
        $builder->setPublished({{ document.getPublished() ? 'true' : 'false' }});
        $builder->save();
        return $builder->getObject();
    }
{% include('@PimcoreContentMigration/code_templates/shared/_dependency_bodies.php.twig') %}
{% else %}
        $builder = {{ builder }}::findOrCreate('{{ document.getFullPath() }}');
{# PAGE SNIPPET BUILDER SETTER #}
{% if isPageSnippet %}
        $builder->setController({% if document.getController() %}'{{ document.getController() }}'{% else %}null{% endif %});
        $builder->setContentMainDocument({{ pcmb_value_to_string(document.getContentMainDocument(), dependencies) }});
        $builder->setTemplate({% if document.getTemplate() %}'{{ document.getTemplate() }}'{% else %}null{% endif %});
{% endif %}
        return $builder->getObject();
    }
{% endif %}
{% endautoescape %}